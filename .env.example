# Example environment variables
# Copy to .env and fill in actual values

# Python configuration
PYTHON_ENV=development

# Import paths (optional)
IMPORT_DATADIR=/path/to/import/data

# DesignBuilder (optional)
DESIGNBUILDER_PATH=C:\Program Files\DesignBuilder\

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Testing
TEST_DATA_DIR=./test_data

# Database (if applicable)
DB_CONNECTION=

# Notes: 
# - Do not commit .env file (it's ignored by .gitignore)
# - Copy this file to .env and fill in your local values
